{
  "name": "grotto",
  "version": "0.1.0",
  "description": "Chat with your notes. Locally. Privately. For free.",
  "type": "module",
  "bin": {
    "grotto": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rag",
    "ai",
    "local-first",
    "notes",
    "ollama",
    "openai",
    "privacy",
    "knowledge-base",
    "second-brain"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/USER/grotto.git"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "ollama": "^0.6.3",
    "openai": "^6.39.1",
    "ora": "^9.4.0",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
